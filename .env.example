# Copy this file to `.env` and fill in your own values.
# Never commit `.env`.

# ─── Supabase (browser-side auth) ──────────────────────────────────────
# The publishable key (sb_publishable_…) is the new-style replacement
# for the legacy anon JWT and is safe to expose to the browser.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase (edge-side JWT verification) ─────────────────────────────
# Same project URL — used by the edge functions to fetch the JWKS
# at https://<url>/auth/v1/.well-known/jwks.json for asymmetric verify.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# ─── Turso (libSQL) ────────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Mistral (AI chat + embeddings) ────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key

# ─── Tavily (web search tool calling) ──────────────────────────────────
# Comma-separated list of 1–4 keys rotated round-robin across requests
# so the free tier stretches further. The first non-rate-limited key
# wins per request.
TAVILY_API_KEYS=tvly-dev-key-1,tvly-dev-key-2

# ─── Workspace integrations encryption key ─────────────────────────────
# Encrypts every connected Google Apps Script secret in the
# workspace_connections table. AES-256 (32 bytes, base64).
#
# Generate with:
#   node scripts/generate-workspace-key.mjs
#
# Rotating this value invalidates every connected workspace; users
# will need to reconnect their Google accounts via Settings.
WORKSPACE_SECRET_KEY=your-base64-encoded-32-byte-key
